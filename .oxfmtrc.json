{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "arrowParens": "always",
  "proseWrap": "preserve",
  "sortPackageJson": true,
  "sortTailwindcss": {
    "functions": ["cn"]
  },
  "ignorePatterns": [],
   "sortImports": {
    "ignoreCase": true,               // 忽略大小写
    "newlinesBetween": true,      // 在导入组之间插入空行
    "groups": [                       // 自定义分组顺序
      "builtin", "external", "internal", "parent", "sibling", "index"
    ]
  }
}
